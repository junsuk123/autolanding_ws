function summary = AutoLandingMain(varargin)
% AUTOLANDINGMAIN
% MATLAB entrypoint for standard workspace execution.

  summary = AutoLandingMainFull(struct( ...
      'mode', 'full', ...
      'num_drones', 2, ...
      'num_landing_pads', 2, ...
      'scenarios_per_worker', 12, ...
      'train_ratio', 0.8, ...
      'val_ratio', 0.2, ...
      'headless', false, ...
      'auto_flight_demo', true, ...
      'drone_spawn_above_pad_m', 0.5));end
