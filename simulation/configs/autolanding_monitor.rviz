Panels:
  - Class: rviz_common/Displays
    Name: Displays
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Name: Tool Properties
  - Class: rviz_common/Views
    Name: Views
  - Class: rviz_common/Time
    Name: Time
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.03
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 50
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Marker Scale: 1
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Update Interval: 0
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: ArUco MarkerArray
      Namespaces:
        "": true
      Queue Size: 10
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /aruco_markers
      Value: true
    - Alpha: 1
      Class: rviz_default_plugins/PoseArray
      Color: 255; 85; 0
      Enabled: true
      Length: 0.3
      Name: ArUco Poses
      Queue Size: 10
      Radius: 0.03
      Shaft Length: 0.25
      Shaft Radius: 0.01
      Shape: Arrow
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /aruco_poses
      Value: true
    - Angle Tolerance: 0.1
      Class: rviz_default_plugins/Odometry
      Enabled: true
      Keep: 100
      Name: Drone Odom (/odom)
      Position Tolerance: 0.1
      Shape:
        Alpha: 1
        Axes Length: 0.2
        Axes Radius: 0.02
        Color: 85; 255; 127
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /odom
      Value: true
    - Angle Tolerance: 0.1
      Class: rviz_default_plugins/Odometry
      Enabled: true
      Keep: 100
      Name: Drone Odom (/mavros/local_position/odom)
      Position Tolerance: 0.1
      Shape:
        Alpha: 1
        Axes Length: 0.2
        Axes Radius: 0.02
        Color: 51; 153; 255
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /mavros/local_position/odom
      Value: true
    - Angle Tolerance: 0.1
      Class: rviz_default_plugins/Odometry
      Enabled: true
      Keep: 100
      Name: Drone1 Odom
      Position Tolerance: 0.1
      Shape:
        Alpha: 1
        Axes Length: 0.25
        Axes Radius: 0.02
        Color: 255; 99; 71
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone1/odom
      Value: true
    - Angle Tolerance: 0.1
      Class: rviz_default_plugins/Odometry
      Enabled: true
      Keep: 100
      Name: Drone2 Odom
      Position Tolerance: 0.1
      Shape:
        Alpha: 1
        Axes Length: 0.25
        Axes Radius: 0.02
        Color: 65; 105; 225
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone2/odom
      Value: true
    - Angle Tolerance: 0.1
      Class: rviz_default_plugins/Odometry
      Enabled: true
      Keep: 100
      Name: Drone3 Odom
      Position Tolerance: 0.1
      Shape:
        Alpha: 1
        Axes Length: 0.25
        Axes Radius: 0.02
        Color: 50; 205; 50
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone3/odom
      Value: true
    - Angle Tolerance: 0.1
      Class: rviz_default_plugins/Odometry
      Enabled: true
      Keep: 100
      Name: Drone4 Odom
      Position Tolerance: 0.1
      Shape:
        Alpha: 1
        Axes Length: 0.25
        Axes Radius: 0.02
        Color: 255; 215; 0
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone4/odom
      Value: true
    - Angle Tolerance: 0.1
      Class: rviz_default_plugins/Odometry
      Enabled: true
      Keep: 100
      Name: Drone5 Odom
      Position Tolerance: 0.1
      Shape:
        Alpha: 1
        Axes Length: 0.25
        Axes Radius: 0.02
        Color: 186; 85; 211
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone5/odom
      Value: true
    - Angle Tolerance: 0.1
      Class: rviz_default_plugins/Odometry
      Enabled: true
      Keep: 100
      Name: Drone6 Odom
      Position Tolerance: 0.1
      Shape:
        Alpha: 1
        Axes Length: 0.25
        Axes Radius: 0.02
        Color: 255; 140; 0
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone6/odom
      Value: true
    - Class: rviz_default_plugins/Path
      Enabled: true
      Name: Drone1 Trail
      Color: 255; 99; 71
      Line Style: Lines
      Line Width: 0.04
      Alpha: 0.95
      Buffer Length: 1
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Style: None
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone1/path
      Value: true
    - Class: rviz_default_plugins/Path
      Enabled: true
      Name: Drone2 Trail
      Color: 65; 105; 225
      Line Style: Lines
      Line Width: 0.04
      Alpha: 0.95
      Buffer Length: 1
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Style: None
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone2/path
      Value: true
    - Class: rviz_default_plugins/Path
      Enabled: true
      Name: Drone3 Trail
      Color: 50; 205; 50
      Line Style: Lines
      Line Width: 0.04
      Alpha: 0.95
      Buffer Length: 1
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Style: None
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone3/path
      Value: true
    - Class: rviz_default_plugins/Path
      Enabled: true
      Name: Drone4 Trail
      Color: 255; 215; 0
      Line Style: Lines
      Line Width: 0.04
      Alpha: 0.95
      Buffer Length: 1
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Style: None
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone4/path
      Value: true
    - Class: rviz_default_plugins/Path
      Enabled: false
      Name: Drone5 Trail
      Color: 186; 85; 211
      Line Style: Lines
      Line Width: 0.04
      Alpha: 0.95
      Buffer Length: 1
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Style: None
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone5/path
      Value: true
    - Class: rviz_default_plugins/Path
      Enabled: false
      Name: Drone6 Trail
      Color: 255; 140; 0
      Line Style: Lines
      Line Width: 0.04
      Alpha: 0.95
      Buffer Length: 1
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Style: None
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /drone6/path
      Value: true
  Enabled: true
  Global Options:
    Background Color: 30; 30; 30
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 8
      Focal Point:
        X: 0
        Y: 0
        Z: 0
      Name: Orbit
      Pitch: 0.8
      Target Frame: map
      Yaw: 0.9
Window Geometry:
  Displays:
    collapsed: false
  Height: 900
  Hide Left Dock: false
  Hide Right Dock: false
  QMainWindow State: 
  Width: 1600
  X: 80
  Y: 60
